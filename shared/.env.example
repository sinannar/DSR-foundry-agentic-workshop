# Azure authentication
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_SUBSCRIPTION_ID=

# Workshop assignment
AZURE_RESOURCE_GROUP=rg-foundry-hol
FOUNDRY_RESOURCE_NAME=foundryhol001
FOUNDRY_PROJECT_NAME=attendee-01

# Attendee RBAC and project provisioning (organizer only)
# AZURE_ATTENDEE_LIST is the single source of truth for both project creation (Bicep)
# and per-attendee role assignment (postprovision hook). It is a single-line JSON array.
# Schema: shared/schemas/attendee-list.schema.json
# Each entry: { "upn": required, "role"?: role key, "individualProject"?: bool (default true),
#   "projectName"?: explicit project name (default "<prefix>-NN" by list position) }.
# Example:
# AZURE_ATTENDEE_LIST=[{"upn":"ana@contoso.com"},{"upn":"ben@contoso.com","role":"foundry-account-owner"},{"upn":"fac@contoso.com","role":"facilitator"}]
AZURE_ATTENDEE_LIST=[]

# Default Foundry role applied to attendees without an explicit "role" in AZURE_ATTENDEE_LIST.
# Valid roles: foundry-user (least privilege; labs 00-07, project scope),
#   foundry-project-manager (publishing; lab 08, account scope),
#   foundry-account-owner (deploy models; account scope),
#   foundry-owner (full build and manage; account scope).
#   facilitator / proctor / organizer (staff; equivalent to foundry-owner at account scope).
AZURE_ATTENDEE_DEFAULT_ROLE=foundry-user

# Fallback project generation when AZURE_ATTENDEE_LIST is empty.
AZURE_ATTENDEE_COUNT=1
AZURE_ATTENDEE_PROJECT_PREFIX=attendee

# Workshop staff project prefixes — each role group gets its own numbered project series.
AZURE_FACILITATOR_PROJECT_PREFIX=facilitator
AZURE_PROCTOR_PROJECT_PREFIX=proctor
AZURE_ORGANIZER_PROJECT_PREFIX=organizer

# Set to false to suppress automatic creation of a facilitator-01 project when no
# facilitator entry appears in AZURE_ATTENDEE_LIST.
AZURE_ENSURE_FACILITATOR_PROJECT=true

# Populated by azd output after provisioning.
FOUNDRY_FACILITATOR_PROJECT_NAME=

# Shared resources
AZURE_SEARCH_SERVICE_NAME=foundryholsearch001
AZURE_STORAGE_ACCOUNT_NAME=foundryholstorage01

# Azure AI Search index names.
AZURE_SEARCH_PRODUCT_INDEX_NAME=retail-products
AZURE_SEARCH_DOCUMENT_INDEX_NAME=retail-policies

# Optional: use key auth for scripts that seed search data.
# If not provided, DefaultAzureCredential is used.
AZURE_SEARCH_ADMIN_KEY=

# OpenAI model deployments (used by data generator and labs).
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=embedding
