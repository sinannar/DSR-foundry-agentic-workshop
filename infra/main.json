{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "3670988087937590867"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for workshop resources"
      }
    },
    "envName": {
      "type": "string",
      "defaultValue": "hol",
      "metadata": {
        "description": "Short environment suffix (e.g. dev, hol, lab)"
      }
    },
    "attendeeCount": {
      "type": "int",
      "defaultValue": 10,
      "minValue": 1,
      "metadata": {
        "description": "Number of attendee Foundry projects to create"
      }
    },
    "attendeeProjectPrefix": {
      "type": "string",
      "defaultValue": "attendee",
      "metadata": {
        "description": "Base name used when generating attendee project names"
      }
    },
    "foundryName": {
      "type": "string",
      "metadata": {
        "description": "Azure AI Foundry resource name"
      }
    },
    "searchName": {
      "type": "string",
      "metadata": {
        "description": "Shared Azure AI Search service name"
      }
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Shared Azure Storage account name (3-24 lowercase alphanumeric)"
      }
    },
    "searchSku": {
      "type": "string",
      "defaultValue": "basic",
      "allowedValues": [
        "basic",
        "standard"
      ],
      "metadata": {
        "description": "SKU for shared Azure AI Search service"
      }
    },
    "foundrySku": {
      "type": "string",
      "defaultValue": "S0",
      "metadata": {
        "description": "SKU for Azure AI Foundry resource"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2024-10-01",
      "name": "[parameters('foundryName')]",
      "location": "[parameters('location')]",
      "kind": "AIServices",
      "sku": {
        "name": "[parameters('foundrySku')]"
      },
      "tags": {
        "workshop": "foundry-agentic",
        "environment": "[parameters('envName')]"
      },
      "properties": {
        "customSubDomainName": "[parameters('foundryName')]",
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.Search/searchServices",
      "apiVersion": "2023-11-01",
      "name": "[parameters('searchName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('searchSku')]"
      },
      "tags": {
        "workshop": "foundry-agentic",
        "environment": "[parameters('envName')]"
      },
      "properties": {
        "replicaCount": 1,
        "partitionCount": 1,
        "publicNetworkAccess": "enabled"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('location')]",
      "kind": "StorageV2",
      "sku": {
        "name": "Standard_LRS"
      },
      "tags": {
        "workshop": "foundry-agentic",
        "environment": "[parameters('envName')]"
      },
      "properties": {
        "allowBlobPublicAccess": false,
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true
      }
    },
    {
      "copy": {
        "name": "attendeeProjects",
        "count": "[length(range(0, parameters('attendeeCount')))]"
      },
      "type": "Microsoft.CognitiveServices/accounts/projects",
      "apiVersion": "2024-10-01-preview",
      "name": "[format('{0}/{1}', parameters('foundryName'), format('{0}-{1}', parameters('attendeeProjectPrefix'), padLeft(string(add(range(0, parameters('attendeeCount'))[copyIndex()], 1)), 2, '0')))]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "[format('{0}-{1}', parameters('attendeeProjectPrefix'), padLeft(string(add(range(0, parameters('attendeeCount'))[copyIndex()], 1)), 2, '0'))]",
        "description": "[format('Workshop attendee project {0}', add(range(0, parameters('attendeeCount'))[copyIndex()], 1))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))]"
      ]
    }
  ],
  "outputs": {
    "foundryResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))]"
    },
    "searchResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Search/searchServices', parameters('searchName'))]"
    },
    "storageAccountId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
    },
    "attendeeProjectNames": {
      "type": "array",
      "copy": {
        "count": "[length(range(0, parameters('attendeeCount')))]",
        "input": "[format('{0}-{1}', parameters('attendeeProjectPrefix'), padLeft(string(add(range(0, parameters('attendeeCount'))[copyIndex()], 1)), 2, '0'))]"
      }
    }
  }
}