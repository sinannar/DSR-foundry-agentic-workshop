{
  "name": "foundry-agentic-workshop",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "type": "module",
  "scripts": {
    "docs:generate-labs": "node scripts/generate-vitepress-labs.mjs",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.git\" \"#infra/.terraform\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\" \"#.git\" \"#infra/.terraform\"",
    "lint:md:ci": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.git\" \"#infra/.terraform\"",
    "docs:dev": "pnpm run docs:generate-labs && vitepress dev docs",
    "docs:build": "pnpm run docs:generate-labs && vitepress build docs",
    "docs:preview": "pnpm run docs:generate-labs && vitepress preview docs"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.22.1",
    "vitepress": "^1.6.4"
  },
  "description": "Microsoft Foundry Agentic Workshop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PlagueHO/foundry-agentic-workshop.git"
  },
  "author": "Daniel Scott-Raynsford",
  "license": "MIT"
}
