{
    "version": "2.0.0",
    "tasks": [
        // Build/Lint tasks
        {
            "label": "python: ruff check",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "ruff", "check", "labs/", "scripts/", "shared/"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "icon": {
                "id": "symbol-method",
                "color": "terminal.ansiBlue"
            },
            "presentation": { "reveal": "always" },
            "problemMatcher": []
        },
        {
            "label": "python: flake8",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "flake8", "labs/", "scripts/", "shared/"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "icon": {
                "id": "symbol-constant",
                "color": "terminal.ansiCyan"
            },
            "problemMatcher": ["$python"],
            "presentation": { "reveal": "always" }
        },
        {
            "label": "python: pylint",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "pylint", "labs/", "scripts/", "shared/"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "icon": {
                "id": "tools",
                "color": "terminal.ansiYellow"
            },
            "problemMatcher": ["$python"]
        },
        {
            "label": "python: mypy",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "mypy", "labs/", "scripts/", "shared/"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "icon": {
                "id": "symbol-class",
                "color": "terminal.ansiMagenta"
            },
            "problemMatcher": ["$python"]
        },

        // Test tasks
        {
            "label": "python: test",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "pytest", "labs/", "scripts/", "shared/"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "icon": {
                "id": "beaker",
                "color": "terminal.ansiGreen"
            },
            "problemMatcher": ["$python"]
        },

        // Bicep tasks
        {
            "label": "infra: build (bicep)",
            "type": "shell",
            "command": "pwsh",
            "args": [
              "-NoProfile",
              "-Command",
              "Get-ChildItem -Path infra -Recurse -Filter '*.bicep' | ForEach-Object { Write-Host \"Building $($_.FullName)...\"; az bicep build --file $($_.FullName) }"
            ],
            "options": {
                "cwd": "${workspaceFolder}/infra"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "icon": {
                "id": "server-environment",
                "color": "terminal.ansiBlue"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "infra: lint (bicep)",
            "type": "shell",
            "command": "az",
            "args": ["bicep", "lint", "--file", "main.bicep"],
            "options": {
                "cwd": "${workspaceFolder}/infra"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "icon": {
                "id": "pass",
                "color": "terminal.ansiCyan"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "azd: provision",
            "type": "shell",
            "command": "azd",
            "args": ["provision"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "icon": {
                "id": "tools",
                "color": "terminal.ansiBlue"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "azd: up",
            "type": "shell",
            "command": "azd",
            "args": ["up"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "icon": {
                "id": "rocket",
                "color": "terminal.ansiGreen"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "azd: down",
            "type": "shell",
            "command": "azd",
            "args": ["down", "--force", "--purge"],
            "options": {
                "cwd": "${workspaceFolder}"
